# Copy this file to .env in $SCRATCH/kyrgyzLLM/ on the Helios cluster and fill in your values.
# Never commit .env to git.
#
#   cp .env.example $SCRATCH/kyrgyzLLM/.env
#   nano $SCRATCH/kyrgyzLLM/.env

HF_TOKEN=hf_your_token_here

# Weights & Biases — get your key at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_team_or_username_here
WANDB_PROJECT=kyrgyz-llm
