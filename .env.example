# Copy to $SCRATCH/cpt_experiments/.env and fill in your values.
# Never commit .env to git.
#
#   cp .env.example $SCRATCH/cpt_experiments/.env
#   nano $SCRATCH/cpt_experiments/.env

# HuggingFace token (required)
HF_TOKEN=hf_your_token_here

# Dataset IDs — Experiment A: equal word budget (100M words per language)
CPT_DATASET_FT_KY_WORDS=org/kyrgyz-100m-words
CPT_DATASET_FT_KZ_WORDS=org/kazakh-100m-words
CPT_DATASET_FT_PL_WORDS=org/polish-100m-words

# Dataset IDs — Experiment B: equal token budget (100M tokens per language)
CPT_DATASET_FT_KY_TOKENS=org/kyrgyz-100m-tokens
CPT_DATASET_FT_KZ_TOKENS=org/kazakh-100m-tokens
CPT_DATASET_FT_PL_TOKENS=org/polish-100m-tokens

# English dataset — fixed 100M words, shared across all languages and experiments
CPT_DATASET_ENGLISH=org/english-100m-words

# Weights & Biases (optional)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_team_or_username_here
WANDB_PROJECT=cpt-experiments
