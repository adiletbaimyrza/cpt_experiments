  <diagram name="3. Grid Search" id="grid">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="g_title" value="Grid Search — How the Winning Hyperparameters Are Picked" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g_subtitle" value="Per model: 4 candidate (rank, learning_rate) combinations are trained on FT-KY only; the lowest eval_loss wins" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#444444;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="1000" height="30" as="geometry" />
        </mxCell>

        <mxCell id="g_in" value="FT-KY data (target language only)&#10;packed sequences + held-out eval split (5%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="400" height="60" as="geometry" />
        </mxCell>

        <mxCell id="g_table_hdr" value="The 4 grid runs (defined in jobs/grid_search.sh)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="220" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="g_run_a" value="Run A&#10;━━━━━━━━━━━&#10;rank = 64&#10;lr = 1e-4&#10;━━━━━━━━━━━&#10;baseline (low rank)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g_run_b" value="Run B&#10;━━━━━━━━━━━&#10;rank = 128&#10;lr = 1e-4&#10;━━━━━━━━━━━&#10;mid rank, baseline lr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g_run_c" value="Run C&#10;━━━━━━━━━━━&#10;rank = 256&#10;lr = 1e-4&#10;━━━━━━━━━━━&#10;high rank" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="660" y="280" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g_run_d" value="Run D&#10;━━━━━━━━━━━&#10;rank = 128&#10;lr = 2e-4&#10;━━━━━━━━━━━&#10;higher lr probe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=center;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="940" y="280" width="240" height="160" as="geometry" />
        </mxCell>

        <mxCell id="g_each_run" value="Each grid run trains for grid_max_steps (default 500) on FT-KY only,&#10;evaluates on the held-out 5% target split, writes grid_search_result.json" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="200" y="450" width="900" height="40" as="geometry" />
        </mxCell>

        <mxCell id="g_pick" value="pick_best_grid.sh&#10;━━━━━━━━━━━━━━━━━━━━━━&#10;winner = argmin(final_eval_loss)&#10;fallback to final_train_loss for very short runs&#10;writes logs/grid_winner_&lt;model&gt;.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;align=center;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="380" y="520" width="600" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g_winner" value="Winner (rank, learning_rate)&#10;applied to all 3 train_KY / train_KZ / train_PL jobs for this model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="350" y="690" width="660" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_note" value="Why FT-KY only?&#10;Searching once on the most resource-constrained language and reusing the winner across KY/KZ/PL&#10;cuts grid cost from 9× to 3× while assuming hyperparameter optima are similar across the 3 target languages.&#10;The grid is repeated independently for each of the 3 base models (Llama / Qwen / gemma)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;dashed=1;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="800" width="1180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_e_in_a" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="1" source="g_in" target="g_run_a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_in_b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="1" source="g_in" target="g_run_b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_in_c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="1" source="g_in" target="g_run_c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_in_d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="1" source="g_in" target="g_run_d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="g_e_a_pick" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;dashed=1" edge="1" parent="1" source="g_run_a" target="g_pick">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_b_pick" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;dashed=1" edge="1" parent="1" source="g_run_b" target="g_pick">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_c_pick" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;dashed=1" edge="1" parent="1" source="g_run_c" target="g_pick">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_e_d_pick" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;dashed=1" edge="1" parent="1" source="g_run_d" target="g_pick">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="g_e_pick_winner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2" edge="1" parent="1" source="g_pick" target="g_winner">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

