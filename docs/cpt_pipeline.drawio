        <mxCell id="p_prep_ky" value="prep_KY&#10;prepare_cpt_data.sh&#10;FT-KY data → packed seqs + eval split" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="280" height="80" as="geometry" />
