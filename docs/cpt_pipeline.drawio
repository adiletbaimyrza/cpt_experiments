        <mxCell id="p_prep_kz" value="prep_KZ&#10;prepare_cpt_data.sh&#10;FT-KZ data → packed seqs + eval split" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="560" y="220" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_prep_pl" value="prep_PL&#10;prepare_cpt_data.sh&#10;FT-PL data → packed seqs + eval split" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1040" y="220" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p_grid_a" value="grid_A&#10;r=64, lr=1e-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_grid_b" value="grid_B&#10;r=128, lr=1e-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="220" y="370" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_grid_c" value="grid_C&#10;r=256, lr=1e-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="400" y="370" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_grid_d" value="grid_D&#10;r=128, lr=2e-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="580" y="370" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="p_pick" value="pick_winner&#10;pick_best_grid.sh&#10;ranks by eval_loss (fallback: train_loss)&#10;writes logs/grid_winner_&lt;model&gt;.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="180" y="490" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p_train_ky" value="train_KY&#10;train_cpt.sh&#10;Phase 1 (EN warmup, ~10%) → Phase 2 (target, ~90%)&#10;reads (lora_r, lr) from winner file at runtime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
